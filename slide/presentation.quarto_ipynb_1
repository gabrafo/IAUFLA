        "#| echo: false\n",
        "#| warning: false\n",
        "\n",
        "import math\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import pandas as pd\n",
        "from sklearn.datasets import load_iris\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.neighbors import KNeighborsClassifier\n",
        "from sklearn.metrics import confusion_matrix, accuracy_score, recall_score\n",
        "\n",
        "class Example:\n",
        "    def __init__(self, X, y):\n",
        "        self.X = X\n",
        "        self.y = y\n",
        "\n",
        "def euclidean_distance(p1, p2):\n",
        "    soma = sum((p1[i] - p2[i]) ** 2 for i in range(len(p1)))\n",
        "    return math.sqrt(soma)\n",
        "\n",
        "def knn(K: int, data: list, new_example: Example):\n",
        "    distances = []\n",
        "    for example in data:\n",
        "        dist = euclidean_distance(example.X, new_example.X)\n",
        "        distances.append([dist, example.y])\n",
        "    distances.sort(key=lambda x: x[0])\n",
        "    neighbors = distances[:K]\n",
        "    counter = {}\n",
        "    for dist, examined_class in neighbors:\n",
        "        counter[examined_class] = counter.get(examined_class, 0) + 1\n",
        "    predicted_class = max(counter, key=lambda c: counter[c])\n",
        "    return predicted_class\n",
        "\n",
        "# Preparação dos dados\n",
        "iris = load_iris()\n",
        "X = iris.data\n",
        "y = iris.target\n",
        "target_names = iris.target_names\n",
        "y_named = [target_names[i] for i in y]\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y_named, test_size=0.2, random_state=42, stratify=y_named\n",
        ")\n",
        "\n",
        "train_data = [Example(x, label) for x, label in zip(X_train, y_train)]\n",
        "test_data = [Example(x, label) for x, label in zip(X_test, y_test)]\n",
        "\n",
        "def plot_confusion_matrices(k):\n",
        "    y_pred_manual = [knn(k, train_data, example) for example in test_data]\n",
        "    \n",
        "    knn_sklearn = KNeighborsClassifier(n_neighbors=k, metric='euclidean')\n",
        "    knn_sklearn.fit(X_train, y_train)\n",
        "    y_pred_sklearn = knn_sklearn.predict(X_test)\n",
        "    \n",
        "    fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
        "    \n",
        "    cm_manual = confusion_matrix(y_test, y_pred_manual, labels=target_names)\n",
        "    sns.heatmap(cm_manual, annot=True, fmt='d', cmap='Blues', \n",
        "                xticklabels=target_names, yticklabels=target_names, ax=axes[0])\n",
        "    axes[0].set_title(f\"Manual - K={k}\")\n",
        "    axes[0].set_xlabel(\"Predito\")\n",
        "    axes[0].set_ylabel(\"Real\")\n",
        "    \n",
        "    cm_sklearn = confusion_matrix(y_test, y_pred_sklearn, labels=target_names)\n",
        "    sns.heatmap(cm_sklearn, annot=True, fmt='d', cmap='Greens', \n",
        "                xticklabels=target_names, yticklabels=target_names, ax=axes[1])\n",
        "    axes[1].set_title(f\"Sklearn - K={k}\")\n",
        "    axes[1].set_xlabel(\"Predito\")\n",
        "    axes[1].set_ylabel(\"Real\")\n",
        "    \n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "def calculate_metrics(k_values):\n",
        "    rows = []\n",
        "    for k in k_values:\n",
        "        y_pred_manual = [knn(k, train_data, example) for example in test_data]\n",
        "\n",
        "        knn_sklearn = KNeighborsClassifier(n_neighbors=k, metric='euclidean')\n",
        "        knn_sklearn.fit(X_train, y_train)\n",
        "        y_pred_sklearn = knn_sklearn.predict(X_test)\n",
        "\n",
        "        rows.append({\n",
        "            \"K\": k,\n",
        "            \"Acuracia Manual\": accuracy_score(y_test, y_pred_manual),\n",
        "            \"Acuracia Sklearn\": accuracy_score(y_test, y_pred_sklearn),\n",
        "            \"Revocacao Manual\": recall_score(y_test, y_pred_manual, average='macro', zero_division=0),\n",
        "            \"Revocacao Sklearn\": recall_score(y_test, y_pred_sklearn, average='macro', zero_division=0),\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def plot_metric_comparison(metrics_df):\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(11, 4))\n",
        "\n",
        "    axes[0].plot(metrics_df[\"K\"], metrics_df[\"Acuracia Manual\"], marker='o', label='Manual')\n",
        "    axes[0].plot(metrics_df[\"K\"], metrics_df[\"Acuracia Sklearn\"], marker='o', label='Sklearn')\n",
        "    axes[0].set_title(\"Acuracia por K\")\n",
        "    axes[0].set_xlabel(\"K\")\n",
        "    axes[0].set_ylabel(\"Acuracia\")\n",
        "\n",
        "    axes[1].plot(metrics_df[\"K\"], metrics_df[\"Revocacao Manual\"], marker='o', label='Manual')\n",
        "    axes[1].plot(metrics_df[\"K\"], metrics_df[\"Revocacao Sklearn\"], marker='o', label='Sklearn')\n",
        "    axes[1].set_title(\"Revocacao por K\")\n",
        "    axes[1].set_xlabel(\"K\")\n",
        "    axes[1].set_ylabel(\"Revocacao\")\n",
        "\n",
        "    for ax in axes:\n",
        "        ax.set_xticks(metrics_df[\"K\"])\n",
        "        ax.set_ylim(0.0, 1.05)\n",
        "        ax.grid(alpha=0.25)\n",
        "        ax.legend()\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "k_values = [1, 3, 5, 7]\n",
        "metrics_df = calculate_metrics(k_values)"
      ],
